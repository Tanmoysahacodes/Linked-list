#include <stdio.h>
#include <stdlib.h>

struct node
{
    int data;
    struct node *next;
};

struct node *head = NULL;

// 🔸 Insert at end
void insert_end(int val)
{
    struct node *temp, *ptr;

    temp = (struct node *)malloc(sizeof(struct node));
    temp->data = val;

    // Empty list
    if (head == NULL)
    {
        temp->next = temp;
        head = temp;
        return;
    }

    ptr = head;
    while (ptr->next != head)
    {
        ptr = ptr->next;
    }

    ptr->next = temp;
    temp->next = head;
}

// 🔸 Create list (n nodes)
void create()
{
    int n, val, i;
    printf("Enter number of nodes: ");
    scanf("%d", &n);

    for (i = 1; i <= n; i++)
    {
        printf("Enter value: ");
        scanf("%d", &val);
        insert_end(val);
    }
}

// 🔸 Display
void display()
{
    struct node *temp;

    if (head == NULL)
    {
        printf("List is empty\n");
        return;
    }

    temp = head;
    do
    {
        printf("%d -> ", temp->data);
        temp = temp->next;
    } while (temp != head);

    printf("(back to %d)\n", head->data);
}

// 🔸 Delete from beginning
void delete_begin()
{
    struct node *temp, *ptr;

    if (head == NULL)
    {
        printf("List is empty\n");
        return;
    }

    // Only one node
    if (head->next == head)
    {
        free(head);
        head = NULL;
        return;
    }

    temp = head;
    ptr = head;

    while (ptr->next != head)
    {
        ptr = ptr->next;
    }

    head = head->next;
    ptr->next = head;

    free(temp);
}

// 🔸 Main
int main()
{
    create();

    printf("\nInitial List:\n");
    display();

    printf("\nAfter inserting at end (99):\n");
    insert_end(99);
    display();

    printf("\nAfter deleting from beginning:\n");
    delete_begin();
    display();

    return 0;
}
