#include <stdio.h>
#include <stdlib.h>

struct node
{
    int data;
    struct node *left;   // previous node
    struct node *right;  // next node
};

struct node *create_node(int data_value)
{
    struct node *ptr;
    ptr = (struct node *)malloc(sizeof(struct node));
    ptr->data = data_value;
    ptr->left = NULL;
    ptr->right = NULL;
    return ptr;
}

void traverse(struct node *start)
{
    struct node *ptr;
    ptr = start;
    while (ptr != NULL)
    {
        printf("%d ", ptr->data);
        ptr = ptr->right;
    }
}

// Insert at beginning
void insert_begin(struct node **start, int data_value)
{
    struct node *new = create_node(data_value);

    if (*start != NULL)
        (*start)->left = new;

    new->right = *start;
    *start = new;
}

// Insert at end
void insert_end(struct node **start, int data_value)
{
    struct node *ptr, *new;
    new = create_node(data_value);

    if (*start == NULL)
    {
        *start = new;
        return;
    }

    ptr = *start;
    while (ptr->right != NULL)
    {
        ptr = ptr->right;
    }

    ptr->right = new;
    new->left = ptr;
}

// Insert at position
void insert_pos(struct node **start, int data_value, int pos)
{
    struct node *ptr, *new;
    int i;

    new = create_node(data_value);

    if (pos == 1)
    {
        insert_begin(start, data_value);
        return;
    }

    ptr = *start;

    for (i = 1; i < pos - 1 && ptr != NULL; i++)
    {
        ptr = ptr->right;
    }

    if (ptr == NULL)
    {
        printf("Invalid position\n");
        return;
    }

    new->right = ptr->right;

    if (ptr->right != NULL)
        ptr->right->left = new;

    ptr->right = new;
    new->left = ptr;
}

// Delete from beginning
void delete_begin(struct node **start)
{
    struct node *temp;

    if (*start == NULL)
        return;

    temp = *start;
    *start = (*start)->right;

    if (*start != NULL)
        (*start)->left = NULL;

    free(temp);
}

// Delete from end
void delete_end(struct node **start)
{
    struct node *ptr;

    if (*start == NULL)
    {
        printf("List is empty\n");
        return;
    }

    ptr = *start;

    if (ptr->right == NULL)
    {
        free(ptr);
        *start = NULL;
        return;
    }

    while (ptr->right != NULL)
    {
        ptr = ptr->right;
    }

    ptr->left->right = NULL;
    free(ptr);
}

// Delete from position
void delete_pos(struct node **start, int pos)
{
    struct node *ptr;
    int i;

    if (*start == NULL)
        return;

    ptr = *start;

    if (pos == 1)
    {
        delete_begin(start);
        return;
    }

    for (i = 1; i < pos && ptr != NULL; i++)
    {
        ptr = ptr->right;
    }

    if (ptr == NULL)
    {
        printf("Invalid position\n");
        return;
    }

    if (ptr->right != NULL)
        ptr->right->left = ptr->left;

    if (ptr->left != NULL)
        ptr->left->right = ptr->right;

    free(ptr);
}

int main()
{
    struct node *start = NULL;
    int choice, value, pos;

    while (1)
    {
        printf("\n--- MENU ---\n");
        printf("1. Insert at Beginning\n");
        printf("2. Insert at End\n");
        printf("3. Insert at Position\n");
        printf("4. Delete from Beginning\n");
        printf("5. Delete from End\n");
        printf("6. Delete from Position\n");
        printf("7. Traverse\n");
        printf("8. Exit\n");

        printf("Enter choice: ");
        scanf("%d", &choice);

        switch (choice)
        {
        case 1:
            printf("Enter value: ");
            scanf("%d", &value);
            insert_begin(&start, value);
            break;

        case 2:
            printf("Enter value: ");
            scanf("%d", &value);
            insert_end(&start, value);
            break;

        case 3:
            printf("Enter value and position: ");
            scanf("%d %d", &value, &pos);
            insert_pos(&start, value, pos);
            break;

        case 4:
            delete_begin(&start);
            break;

        case 5:
            delete_end(&start);
            break;

        case 6:
            printf("Enter position: ");
            scanf("%d", &pos);
            delete_pos(&start, pos);
            break;

        case 7:
            traverse(start);
            break;

        case 8:
            exit(0);

        default:
            printf("Invalid choice!\n");
        }
    }

    return 0;
}
