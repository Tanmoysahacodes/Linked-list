#include <stdio.h>
#define MAX 100

int avail;

void create(int link[], int prev[], int *start)
{
    for (int i = 0; i < MAX - 1; i++)
    {
        link[i] = i + 1;
        prev[i] = -1;   // NEW
    }
    link[MAX - 1] = -1;
    prev[MAX - 1] = -1;

    avail = 0;
    *start = -1;
}

void insertBegin(int data[], int link[], int prev[], int *start, int val)
{
    if (avail == -1)
    {
        printf("Overflow \n");
        return;
    }

    int p = avail;
    avail = link[p];

    data[p] = val;

    link[p] = *start;
    prev[p] = -1;  // NEW

    if (*start != -1)
        prev[*start] = p;  // NEW

    *start = p;
}

void insertEnd(int data[], int link[], int prev[], int *start, int val)
{
    if (avail == -1)
    {
        printf("Overflow \n");
        return;
    }

    int p = avail;
    avail = link[p];

    data[p] = val;
    link[p] = -1;

    if (*start == -1)
    {
        prev[p] = -1; // NEW
        *start = p;
    }
    else
    {
        int temp = *start;
        while (link[temp] != -1)
        {
            temp = link[temp];
        }

        link[temp] = p;
        prev[p] = temp; // NEW
    }
}

void insertPos(int data[], int link[], int prev[], int *start, int pos, int val)
{
    if (avail == -1)
    {
        printf("Overflow \n");
        return;
    }

    int p = avail;
    avail = link[p];

    data[p] = val;

    if (pos == 1)
    {
        insertBegin(data, link, prev, start, val);
        return;
    }

    int temp = *start;
    for (int i = 1; i < pos - 1; i++)
    {
        if (temp == -1)
        {
            printf("Out of range \n");
            return;
        }
        temp = link[temp];
    }

    link[p] = link[temp];
    prev[p] = temp;   // NEW

    if (link[temp] != -1)
        prev[link[temp]] = p;  // NEW

    link[temp] = p;
}

void deleteBegin(int link[], int prev[], int *start)
{
    if (*start == -1)
    {
        printf("Underflow \n");
        return;
    }

    int temp = *start;
    *start = link[temp];

    if (*start != -1)
        prev[*start] = -1; // NEW

    link[temp] = avail;
    avail = temp;
}

void deleteEnd(int link[], int prev[], int *start)
{
    if (*start == -1)
    {
        printf("Underflow \n");
        return;
    }

    int temp = *start;

    if (link[temp] == -1)
    {
        *start = -1;
        link[temp] = avail;
        avail = temp;
        return;
    }

    while (link[temp] != -1)
    {
        temp = link[temp];
    }

    int p = prev[temp]; // NEW
    link[p] = -1;

    link[temp] = avail;
    avail = temp;
}

void deletePos(int link[], int prev[], int *start, int pos)
{
    if (*start == -1)
    {
        printf("Underflow\n");
        return;
    }

    int temp = *start;

    if (pos == 1)
    {
        deleteBegin(link, prev, start);
        return;
    }

    for (int i = 1; i < pos; i++)
    {
        if (temp == -1)
        {
            printf("Out of range\n");
            return;
        }
        temp = link[temp];
    }

    int p = prev[temp];   // NEW
    int n = link[temp];   // NEW

    if (n != -1)
        prev[n] = p;

    link[p] = n;

    link[temp] = avail;
    avail = temp;
}

void display(int data[], int link[], int start)
{
    int temp = start;
    while (temp != -1)
    {
        printf("%d <-> ", data[temp]); // CHANGED
        temp = link[temp];
    }
    printf("NULL\n");
}

int main()
{
    int d[MAX], l[MAX], p[MAX]; // NEW prev array
    int st;

    create(l, p, &st);

    insertBegin(d, l, p, &st, 10);
    insertEnd(d, l, p, &st, 20);
    insertEnd(d, l, p, &st, 30);
    insertPos(d, l, p, &st, 2, 15);

    display(d, l, st);

    deletePos(l, p, &st, 2);
    display(d, l, st);

    return 0;
}
